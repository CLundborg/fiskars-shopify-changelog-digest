{
  "name": "fiskars-shopify-changelog-digest",
  "version": "0.1.0",
  "private": true,
  "description": "Posts a daily digest of new Shopify developer changelog entries to Slack.",
  "type": "module",
  "scripts": {
    "build": "tsc -p .",
    "dev": "tsc -w",
    "typecheck": "tsc --noEmit",
    "start": "node dist/digest.js",
    "dry-run": "node dist/digest.js --dry-run"
  },
  "dependencies": {
    "fast-xml-parser": "^4.5.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^20.12.0"
  }
}
